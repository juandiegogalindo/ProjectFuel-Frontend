<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- TOOLBAR -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#810615"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:title="Subsidios"
        app:titleTextColor="@android:color/white"/>

    <!-- CONTENIDO -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- TITULO -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Consulta de Subsidio"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_marginBottom="8dp"/>

            <!-- DESCRIPCION -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ingrese su código para validar disponibilidad del subsidio."
                android:textSize="14sp"
                android:textColor="#666666"
                android:layout_marginBottom="24dp"/>

            <!-- INPUT CODIGO -->
            <EditText
                android:id="@+id/etCodigoSubsidio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Ingrese código subsidio"
                android:inputType="textCapCharacters"
                android:maxLength="8"
                android:padding="14dp"
                android:background="@android:drawable/edit_text"
                android:textSize="16sp"/>

            <!-- BOTON -->
            <Button
                android:id="@+id/btnSolicitarSubsidio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Validar Subsidio"
                android:textStyle="bold"/>

            <!-- CARD RESULTADO -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardResultado"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:visibility="gone"
                app:cardCornerRadius="14dp"
                app:cardElevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- ESTADO -->
                    <TextView
                        android:id="@+id/tvEstadoSubsidio"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="APROBADO"
                        android:textStyle="bold"
                        android:textSize="22sp"
                        android:textColor="#008000"/>

                    <!-- MENSAJE -->
                    <TextView
                        android:id="@+id/tvMensajeSubsidio"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Subsidio disponible"
                        android:textSize="16sp"
                        android:layout_marginTop="10dp"/>

                    <!-- MONTO -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Monto:"
                        android:textStyle="bold"
                        android:layout_marginTop="18dp"/>

                    <TextView
                        android:id="@+id/tvMontoSubsidio"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$ 0"
                        android:textSize="18sp"/>

                    <!-- FECHA -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Válido hasta:"
                        android:textStyle="bold"
                        android:layout_marginTop="18dp"/>

                    <TextView
                        android:id="@+id/tvVencimientoSubsidio"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2026-12-31"
                        android:textSize="16sp"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </ScrollView>

</LinearLayout>